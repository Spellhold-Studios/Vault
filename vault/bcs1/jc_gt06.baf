IF
	GlobalGT("TheVault","GLOBAL",0)
	Entered([ANYONE])
THEN
	RESPONSE #100
		DisplayString(LastTrigger,14381) // Trap Sprung
		ForceSpell(LastTrigger,WIZARD_FLAME_ARROW)
		Wait(10)
		ForceSpell(LastTrigger,WIZARD_FLAME_ARROW)
		Wait(10)
		ForceSpell(LastTrigger,WIZARD_FLAME_ARROW)
		Wait(10)
		ForceSpell(LastTrigger,WIZARD_FLAME_ARROW)
END


