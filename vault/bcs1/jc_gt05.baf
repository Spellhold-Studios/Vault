IF
	Global("ReturnNashQuest","GLOBAL",7)
	Entered([ANYONE])
THEN
	RESPONSE #100
		DisplayString(LastTrigger,14381) // Trap Sprung
		ForceSpell(LastTrigger,TRAP_ARROW)
		Wait(10)
		ForceSpell(LastTrigger,WIZARD_MELF_ACID_ARROW)
		Wait(10)
		ForceSpell(LastTrigger,TRAP_ARROW)
		Wait(10)
		ForceSpell(LastTrigger,WIZARD_MELF_ACID_ARROW)
END


