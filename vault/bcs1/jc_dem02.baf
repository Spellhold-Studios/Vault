IF
	See(NearestEnemyOf(Myself))
	Global("Dem2Behave","GLOBAL",4)
THEN
	RESPONSE #20
		ForceSpell([PC],FEAR)
		Wait(2)
		ForceSpell([PC],CLERIC_FLAME_STRIKE)
		Wait(2)
		AttackOneRound(NearestEnemyOf(Myself))
